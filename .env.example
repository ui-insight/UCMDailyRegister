# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./ucm_newsletter.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/ucm_newsletter

# LLM Provider ("claude" or "openai")
LLM_PROVIDER=claude

# Anthropic (required when LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# File uploads
UPLOAD_DIR=./uploads

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173
