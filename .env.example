# Database
DATABASE_URL=sqlite+aiosqlite:///./ucm_newsletter.db

# LLM Provider: "claude" or "openai"
LLM_PROVIDER=claude

# Anthropic (required if LLM_PROVIDER=claude)
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-20250514

# OpenAI (required if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# App
UPLOAD_DIR=./uploads
CORS_ORIGINS=["http://localhost:5173"]
